<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <!-- ===== LOGO AREA ===== -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="48dp">

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/circle_blue_light"/>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_leaf"
                app:tint="#10B981"
                android:contentDescription="App Logo"/>
        </FrameLayout>

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Smart Living"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E293B"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"
            android:text="Kelola kesehatan Anda dengan cerdas"
            android:textSize="13sp"
            android:textColor="#94A3B8"/>

        <!-- ===== CARD FORM ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Judul card -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang Kembali"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="24dp"/>

                <!-- Label Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="6dp"/>

                <!-- Input Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        app:tint="#64748B"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Email Icon"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="nama@email.com"
                        android:textColorHint="#CBD5E1"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:background="@null"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Label Password + Lupa Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Password"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"/>

                    <TextView
                        android:id="@+id/tvLupaPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lupa Password?"
                        android:textSize="12sp"
                        android:textColor="#2563EB"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Input Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#64748B"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Password Icon"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="••••••••"
                        android:textColorHint="#CBD5E1"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Ingat Saya -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:id="@+id/cbIngatSaya"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#2563EB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingat saya"
                        android:textSize="13sp"
                        android:textColor="#64748B"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Tombol MASUK -->
                <TextView
                    android:id="@+id/btnMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:text="Masuk"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_primary"
                    android:layout_marginBottom="20dp"/>

                <!-- Divider ATAU -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ATAU MASUK DENGAN  "
                        android:textSize="10sp"
                        android:textColor="#94A3B8"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0"/>
                </LinearLayout>

                <!-- Tombol Google -->
                <LinearLayout
                    android:id="@+id/btnGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/button_outline"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_google"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Google Icon"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google"
                        android:textSize="15sp"
                        android:textColor="#1E293B"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Link Daftar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? "
                android:textSize="13sp"
                android:textColor="#94A3B8"/>

            <TextView
                android:id="@+id/tvDaftar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar sekarang"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2563EB"
                android:padding="4dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
