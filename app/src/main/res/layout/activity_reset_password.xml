<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollViewReset"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true"
    android:isScrollContainer="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:layout_gravity="start"
            android:src="@drawable/ic_back"
            android:contentDescription="Kembali"
            app:tint="#1E293B"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Card Form -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Judul -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buat Kata Sandi Baru"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"/>

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:text="Pastikan kata sandi baru Anda kuat dan belum pernah digunakan sebelumnya."
                    android:textSize="13sp"
                    android:textColor="#94A3B8"/>

                <!-- ===== KATA SANDI BARU ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kata Sandi Baru"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#64748B"
                        android:layout_marginEnd="8dp"/>

                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Min. 8 karakter"
                        android:textColorHint="#CBD5E1"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:singleLine="true"/>

                    <ImageView
                        android:id="@+id/ivTogglePassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="#94A3B8"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Password Strength -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <View android:id="@+id/strengthBar1" android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E2E8F0"/>
                        <View android:id="@+id/strengthBar2" android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E2E8F0"/>
                        <View android:id="@+id/strengthBar3" android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#E2E8F0"/>
                        <View android:id="@+id/strengthBar4" android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:background="#E2E8F0"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPasswordStrength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masukkan password"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <!-- ===== KONFIRMASI KATA SANDI ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konfirmasi Kata Sandi"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#64748B"
                        android:layout_marginEnd="8dp"/>

                    <EditText
                        android:id="@+id/etKonfirmasiPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Ulangi kata sandi baru"
                        android:textColorHint="#CBD5E1"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:singleLine="true"/>

                    <ImageView
                        android:id="@+id/ivToggleKonfirmasi"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="#94A3B8"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- ===== TOMBOL PERBARUI ===== -->
                <TextView
                    android:id="@+id/btnPerbarui"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:text="Perbarui Password"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_primary"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
