<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- ===== TOP BAR ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="8dp"
        android:background="#F8FAFC">

        <!-- (Removed btnBack) -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Kontrol Perangkat"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#1E293B" />

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="10dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Pengaturan"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#94A3B8" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- ===== TAB SWITCHER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabOtomatis"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Otomatis"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tabManual"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Manual"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#2563EB"
                    android:background="@drawable/bg_tab_selected" />
            </LinearLayout>

            <!-- Tab description -->
            <TextView
                android:id="@+id/tvTabDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="Mode Manual aktif. Kendali penuh."
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:gravity="center" />

            <!-- ===== SECTION LABEL ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERANGKAT TERHUBUNG"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#94A3B8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="14dp" />

            <!-- ===== CARD: PEMANAS RUANGAN ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EDEFF2"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Row: Icon + Name/Status + Switch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- Icon Background Circle -->
                        <FrameLayout
                            android:id="@+id/iconHeaterBg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/circle_orange_light">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_threshold"
                                android:contentDescription="Icon Pemanas"
                                app:tint="#F97316" />
                        </FrameLayout>

                        <!-- Name + Status -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iconHeaterBg"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pemanas Ruangan"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="15sp"
                                android:textColor="#1E293B" />

                            <TextView
                                android:id="@+id/tvPemanahStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Nonaktif"
                                android:textSize="12sp"
                                android:textColor="#94A3B8"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Switch -->
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPemanas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="#F1F5F9" />

                    <!-- Ambang Batas Label Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_threshold"
                            android:contentDescription="Ambang Batas"
                            app:tint="#94A3B8" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Ambang Batas"
                            android:textSize="13sp"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/tvSuhuValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20°C"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#2563EB"
                            android:background="@drawable/bg_tag_blue_light"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- SeekBar -->
                    <SeekBar
                        android:id="@+id/seekBarSuhu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="15"
                        android:progress="5"
                        android:splitTrack="false"
                        android:thumbTint="#2563EB"
                        android:progressTint="#2563EB"
                        android:progressBackgroundTint="#E2E8F0" />

                    <!-- Min/Max labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15°C"
                            android:textSize="11sp"
                            android:textColor="#CBD5E1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30°C"
                            android:textSize="11sp"
                            android:textColor="#CBD5E1" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ===== SECTION LABEL: AKTIVITAS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKTIVITAS TERKINI"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#94A3B8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="18dp" />

            <!-- ===== AKTIVITAS LIST ===== -->
            <LinearLayout
                android:id="@+id/containerAktivitas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memuat aktivitas..."
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:gravity="center"
                    android:layout_marginVertical="20dp"/>
            </LinearLayout>

            <!-- ===== LIHAT SEMUA AKTIVITAS ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLihatSemua"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lihat Semua Aktivitas →"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:elevation="0dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAV ===== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/Widget.MaterialComponents.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemRippleColor="@null"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
