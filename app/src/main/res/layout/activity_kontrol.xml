<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- ===== TOP BAR ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Kembali"
            app:tint="#94A3B8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Kontrol Perangkat"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Pengaturan"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#94A3B8" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ===== TAB SWITCHER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabOtomatis"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Otomatis"
                    android:textSize="14sp"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tabManual"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Manual"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2563EB"
                    android:background="@drawable/bg_tab_selected" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTabDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mode Manual aktif. Kendali penuh."
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERANGKAT TERHUBUNG"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <!-- ===== PEMANAS RUANGAN ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/iconHeater"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/circle_orange_light"
                            android:padding="10dp"
                            android:contentDescription="Icon Pemanas" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iconHeater"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pemanas Ruangan"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:textColor="#1E293B" />

                            <TextView
                                android:id="@+id/tvPemanahStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Nonaktif"
                                android:textSize="12sp"
                                android:textColor="#94A3B8" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPemanas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_threshold"
                            android:contentDescription="Icon Ambang Batas"
                            app:tint="#94A3B8" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Ambang Batas"
                            android:textSize="13sp"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/tvSuhuValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20°C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2563EB"
                            android:background="@drawable/bg_tag_blue_light"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarSuhu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:max="15"
                        android:progress="5"
                        android:splitTrack="false"
                        android:progressDrawable="@null"
                        android:thumbTint="#2563EB" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15°C"
                            android:textSize="11sp"
                            android:textColor="#CBD5E1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30°C"
                            android:textSize="11sp"
                            android:textColor="#CBD5E1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== PEMBERSIH UDARA ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2563EB33"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/iconPurifier"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/circle_blue_light"
                            android:padding="10dp"
                            android:contentDescription="Icon Pembersih" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iconPurifier"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pembersih Udara"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:textColor="#1E293B" />

                            <TextView
                                android:id="@+id/tvPembersihStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Aktif"
                                android:textSize="12sp"
                                android:textColor="#2563EB" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPembersih"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- AQI -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="AQI" android:textSize="11sp" android:textColor="#94A3B8" />
                            <TextView
                                android:id="@+id/tvAQI"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="32" android:textSize="17sp" android:textStyle="bold" android:textColor="#2563EB" />
                        </LinearLayout>

                        <View android:layout_width="12dp" android:layout_height="1dp" />

                        <!-- MODE -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MODE" android:textSize="11sp" android:textColor="#94A3B8" />
                            <TextView
                                android:id="@+id/tvModePurifier"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Auto" android:textSize="15sp" android:textStyle="bold" android:textColor="#1E293B" />
                        </LinearLayout>

                        <View android:layout_width="12dp" android:layout_height="1dp" />

                        <!-- FAN -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="FAN" android:textSize="11sp" android:textColor="#94A3B8" />
                            <TextView
                                android:id="@+id/tvFanPurifier"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Med" android:textSize="15sp" android:textStyle="bold" android:textColor="#1E293B" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== PELEMBAB UDARA ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iconHumidifier"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/circle_blue_light"
                        android:padding="10dp"
                        android:alpha="0.5"
                        android:contentDescription="Icon Pelembab" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iconHumidifier"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pelembab Udara"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#1E293B" />

                        <TextView
                            android:id="@+id/tvHumidifierStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Offline"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_stat_card"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="Offline"
                        android:textSize="11sp"
                        android:textColor="#94A3B8" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== AKTIVITAS TERKINI ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKTIVITAS TERKINI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Log 1 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <View android:id="@+id/dot1" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/circle_dot_active" android:layout_marginTop="6dp" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/dot1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pembersih Udara Menyala" android:textStyle="bold" android:textSize="14sp" android:textColor="#1E293B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AQI terdeteksi di atas 50 (Sedang)" android:textSize="12sp" android:textColor="#94A3B8" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" android:text="10:42" android:textSize="11sp" android:textColor="#CBD5E1" />
                </RelativeLayout>

                <!-- Log 2 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <View android:id="@+id/dot2" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/circle_dot_inactive" android:layout_marginTop="6dp" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/dot2" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pemanas Ruangan Mati" android:textStyle="bold" android:textSize="14sp" android:textColor="#1E293B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Suhu mencapai target 24°C" android:textSize="12sp" android:textColor="#94A3B8" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" android:text="08:15" android:textSize="11sp" android:textColor="#CBD5E1" />
                </RelativeLayout>

                <!-- Log 3 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">
                    <View android:id="@+id/dot3" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/circle_dot_inactive" android:layout_marginTop="6dp" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/dot3" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mode Otomatis Diaktifkan" android:textStyle="bold" android:textSize="14sp" android:textColor="#1E293B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pengaturan pengguna" android:textSize="12sp" android:textColor="#94A3B8" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" android:text="Kemarin" android:textSize="11sp" android:textColor="#CBD5E1" />
                </RelativeLayout>
            </LinearLayout>

            <!-- LIHAT SEMUA -->
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lihat Semua Aktivitas →"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:elevation="0dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAV ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:elevation="16dp"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemRippleColor="@null"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
