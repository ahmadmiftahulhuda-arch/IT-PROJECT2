<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="22sp"
                    android:textColor="#1E293B"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kontrol Perangkat"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️"
                    android:textSize="20sp"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- ===== TAB OTOMATIS / MANUAL ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tabOtomatis"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Otomatis"
                    android:textSize="14sp"
                    android:textColor="#94A3B8"/>

                <TextView
                    android:id="@+id/tabManual"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Manual"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2563EB"
                    android:background="@drawable/bg_tab_selected"/>

            </LinearLayout>

            <!-- Subtitle tab -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvTabDesc"
                android:text="Mode Manual aktif. Kendali penuh."
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"/>

            <!-- ===== LABEL PERANGKAT ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERANGKAT TERHUBUNG"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:layout_marginBottom="10dp"/>

            <!-- ===== CARD PEMANAS RUANGAN ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Row: icon + nama + toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp">
                            <View android:layout_width="44dp" android:layout_height="44dp"
                                android:background="@drawable/circle_orange_light"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🔥" android:textSize="20sp"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pemanas Ruangan"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:textColor="#1E293B"/>
                            <TextView
                                android:id="@+id/tvPemanahStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Nonaktif"
                                android:textSize="12sp"
                                android:textColor="#94A3B8"/>
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPemanas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginVertical="12dp"/>

                    <!-- Slider Ambang Batas Suhu -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌡️  Ambang Batas"
                            android:textSize="13sp"
                            android:textColor="#64748B"/>

                        <TextView
                            android:id="@+id/tvSuhuValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20°C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2563EB"
                            android:background="@drawable/bg_tag_blue_light"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"/>
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarSuhu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="20"
                        android:progress="5"
                        android:progressTint="@color/blue_primary"
                        android:thumbTint="@color/blue_primary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15°C" android:textSize="11sp"
                            android:textColor="#94A3B8"/>
                        <View android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="35°C" android:textSize="11sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== CARD PEMBERSIH UDARA ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Row: icon + nama + toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                            <View android:layout_width="44dp" android:layout_height="44dp"
                                android:background="@drawable/circle_blue_light"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="💨" android:textSize="20sp"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pembersih Udara"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:textColor="#1E293B"/>
                            <TextView
                                android:id="@+id/tvPembersihStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Aktif"
                                android:textSize="12sp"
                                android:textColor="#16A34A"/>
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPembersih"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                    <!-- Stats AQI, MODE, FAN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_container"
                        android:padding="12dp">

                        <!-- AQI -->
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AQI" android:textSize="11sp"
                                android:textColor="#94A3B8"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="32" android:textSize="20sp"
                                android:textStyle="bold" android:textColor="#2563EB"/>
                        </LinearLayout>

                        <!-- Divider -->
                        <View android:layout_width="1dp" android:layout_height="40dp"
                            android:background="#E2E8F0"/>

                        <!-- MODE -->
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MODE" android:textSize="11sp"
                                android:textColor="#94A3B8"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="#1E293B"/>
                        </LinearLayout>

                        <!-- Divider -->
                        <View android:layout_width="1dp" android:layout_height="40dp"
                            android:background="#E2E8F0"/>

                        <!-- FAN -->
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FAN" android:textSize="11sp"
                                android:textColor="#94A3B8"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Med" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="#1E293B"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== CARD PELEMBAB UDARA ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <View android:layout_width="44dp" android:layout_height="44dp"
                            android:background="@drawable/circle_blue_light"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="💧" android:textSize="20sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pelembab Udara"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#1E293B"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Offline"
                            android:textSize="12sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:background="@drawable/bg_tag_gray"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== AKTIVITAS TERKINI ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKTIVITAS TERKINI"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:layout_marginBottom="10dp"/>

            <!-- Log 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_dot_active"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pembersih Udara Menyala"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1E293B"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AQI terdeteksi di atas 50 (Sedang)"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19:42"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <!-- Log 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_dot_inactive"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pemanas Ruangan Mati"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1E293B"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suhu mencapai target 24°C"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:15"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <!-- Log 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_dot_inactive"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mode Otomatis Diaktifkan"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1E293B"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan pengguna"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kemarin"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <!-- Lihat Semua -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lihat Semua Aktivitas →"
                android:textSize="13sp"
                android:textColor="#2563EB"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemIconSize="24dp"
        app:itemRippleColor="@null"
        app:elevation="16dp"/>

</LinearLayout>