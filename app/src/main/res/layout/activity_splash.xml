<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <!-- Spacer atas -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"/>

    <!-- Lingkaran biru muda + icon daun -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp">

        <!-- Background lingkaran -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:background="@drawable/circle_blue_light"/>

        <!-- Icon daun (pakai emoji sementara kalau belum ada icon) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🌿"
            android:textSize="48sp"/>

    </FrameLayout>

    <!-- Garis kecil bawah logo -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_marginTop="12dp"
        android:background="@color/blue_primary"/>

    <!-- Judul Smart Living -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Smart Living"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:fontFamily="sans-serif-medium"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="PURITY IN EVERY BREATH"
        android:textSize="11sp"
        android:textColor="@color/text_gray"
        android:letterSpacing="0.15"/>

    <!-- Spacer tengah -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"/>

    <!-- Progress bar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="220dp"
        android:layout_height="5dp"
        android:progress="55"
        android:progressTint="@color/blue_primary"
        android:progressBackgroundTint="@color/divider"
        android:indeterminate="false"/>

    <!-- Teks bawah progress -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="SETTING UP YOUR HEALTHY HOME"
        android:textSize="10sp"
        android:textColor="@color/text_gray"
        android:letterSpacing="0.1"/>

    <!-- Dot indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_dot_active"
            android:layout_marginEnd="4dp"/>

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_dot_inactive"/>

    </LinearLayout>

    <!-- Secure Smart Sync -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="30dp"
        android:text="🔒  SECURE SMART SYNC"
        android:textSize="10sp"
        android:textColor="@color/text_gray"
        android:letterSpacing="0.1"/>

</LinearLayout>