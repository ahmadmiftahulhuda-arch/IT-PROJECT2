<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <!-- Spacer atas -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"/>

    <!-- App Logo (Asthma Lungs) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/app_logo"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedSquare" />

    <!-- Judul SMART ASTHMA -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="SMART\nASTHMA"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:fontFamily="sans-serif-bold"/>

    <!-- Spacer tengah -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"/>

    <!-- Progress bar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="220dp"
        android:layout_height="4dp"
        android:progress="40"
        android:progressTint="#2563EB"
        android:progressBackgroundTint="#F1F5F9"
        android:indeterminate="false"/>

    <!-- Teks bawah progress -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="SETTING UP YOUR HEALTHY HOME"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#64748B"
        android:letterSpacing="0.05"/>

    <!-- Dot indicator (3 dots) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_dot_active"
            android:layout_marginEnd="5dp"/>

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_dot_inactive"
            android:layout_marginEnd="5dp"/>
            
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_dot_inactive"/>

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="30dp" />

    <!-- Secure Smart Sync -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">
        
        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_shield_check"
            android:layout_marginEnd="6dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURE SMART SYNC"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#94A3B8"
            android:letterSpacing="0.1"/>
    </LinearLayout>

</LinearLayout>