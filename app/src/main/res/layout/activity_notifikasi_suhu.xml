<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_notif_gradient"
    android:padding="28dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"/>

    <!-- Icon Peringatan (Mirip Gambar) -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="32dp">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_orange_light"
            android:alpha="0.4"/>
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#EF4444"/>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PERINGATAN"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:letterSpacing="0.02"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SUHU BERBAHAYA!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#EF4444"
        android:layout_marginTop="2dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suhu saat ini telah melebihi batas aman yang ditentukan."
        android:textSize="15sp"
        android:textColor="#64748B"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:lineSpacingExtra="4dp"
        android:layout_marginHorizontal="24dp"/>

    <!-- Card Info Suhu (Persis Gambar) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FEE2E2"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">

            <!-- Aksen Merah di Samping -->
            <View
                android:layout_width="5dp"
                android:layout_height="56dp"
                android:background="#EF4444"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡️"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUHU"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#64748B"
                        android:layout_marginBottom="10dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● KRITIS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_badge_red"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ambil tindakan!"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"/>

    <!-- Action Buttons (Gradient & Style sesuai gambar) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Aktifkan Pemanas"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        android:backgroundTint="@null"
        android:background="@drawable/bg_button_blue_gradient"
        app:icon="@drawable/ic_moon"
        app:iconGravity="textStart"
        app:iconPadding="14dp"
        android:layout_marginBottom="16dp"
        app:elevation="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHubungi"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Hubungi Keluarga"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textColor="#1E293B"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1.5dp"
        app:cornerRadius="32dp"
        app:icon="@drawable/ic_person"
        app:iconGravity="textStart"
        app:iconPadding="14dp"
        app:iconTint="#3ABEF9"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/btnTutup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saya Aman, Tutup bakekok"
        android:textSize="15sp"
        android:textColor="#94A3B8"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
